---
import { ClientRouter } from "astro:transitions";
import AppSidebar from "../components/chrome/AppSidebar.astro";
import SearchModal from "../components/chrome/SearchModal.astro";
import GridOverlay from "../components/chrome/GridOverlay.astro";
import ThemeInit from "../components/chrome/ThemeInit.astro";

type Props = {
  title?: string;
};

const { title = "CommandCenter" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ThemeInit />
    <ClientRouter />
  </head>
  <body class="app-shell">
    <AppSidebar transition:persist />
    <SearchModal />
    <GridOverlay />
    <main class="app-shell__content">
      <slot />
    </main>

    <style is:global>
      :root,
      html[data-theme="dark"] {
        --cc-bg: #0a0a0a;
        --cc-surface: #0f0f10;
        --cc-surface-2: #17171a;
        --cc-text: #ffffff;
        --cc-text-secondary: rgba(255, 255, 255, 0.72);
        --cc-text-muted: rgba(255, 255, 255, 0.5);
        --cc-border: rgba(255, 255, 255, 0.08);
        --cc-border-strong: rgba(255, 255, 255, 0.12);
        --cc-hover-bg: rgba(255, 255, 255, 0.06);
        --cc-active-bg: rgba(255, 255, 255, 0.08);
        --cc-accent: #7dffb3;
        --cc-danger: #ff6b6b;
        --cc-backdrop: rgba(0, 0, 0, 0.55);
        --cc-shadow: rgba(0, 0, 0, 0.5);
      }

      html[data-theme="light"] {
        --cc-bg: #ffffff;
        --cc-surface: #f4f4f5;
        --cc-surface-2: #ffffff;
        --cc-text: #0f0f10;
        --cc-text-secondary: rgba(0, 0, 0, 0.65);
        --cc-text-muted: rgba(0, 0, 0, 0.45);
        --cc-border: rgba(0, 0, 0, 0.1);
        --cc-border-strong: rgba(0, 0, 0, 0.14);
        --cc-hover-bg: rgba(0, 0, 0, 0.05);
        --cc-active-bg: rgba(0, 0, 0, 0.07);
        --cc-accent: #16a34a;
        --cc-danger: #dc2626;
        --cc-backdrop: rgba(0, 0, 0, 0.25);
        --cc-shadow: rgba(0, 0, 0, 0.18);
      }

      html,
      body {
        font-size: 18px;
        margin: 0;
        min-height: 100vh;
        background: var(--cc-bg);
        color: var(--cc-text);
        font-family:
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        transition:
          background 0.15s ease,
          color 0.15s ease;
      }

      .app-shell__content {
        margin-left: 240px;
        min-height: 100vh;
        padding: 32px 32px 32px 16px;
        transition: margin-left 0.32s cubic-bezier(0.625, 0.05, 0, 1);
      }

      html.sidebar-collapsed .app-shell__content {
        margin-left: 68px;
      }

      @media (max-width: 900px) {
        .app-shell__content,
        html.sidebar-collapsed .app-shell__content {
          margin-left: 0;
        }
      }
    </style>
  </body>
</html>
