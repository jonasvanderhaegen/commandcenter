---
// Landing-page number odometer, driven live by the event bus.
//
// A rolling-digit counter adapted from Osmo's "Number Odometer" (each digit is
// a masked vertical 0-9 strip translated to the target digit; non-digit
// characters stay static). Reworked as a CSS-transition roller with no GSAP,
// and driven by the event bus instead of scroll: the `set_odometer` MCP tool
// (src-tauri/crates/cc-mcp) publishes on topic "odometer" and the value arrives
// here over WebTransport (when the webview supports it) or WebSocket otherwise
// -- both feed the same window.__ccEvents subscription (see EventBusInit.astro).
//
// The page subscribes when it enters (astro:page-load, if #cc-odometer is in
// the DOM) and unsubscribes when it leaves (astro:before-swap), mirroring the
// AppSidebar re-wiring pattern for Astro's ClientRouter.
---

<div class="odometer-card">
  <p class="odometer-card__label">
    Live value
    <span class="odometer-card__hint">set via the <code>set_odometer</code> MCP tool &rarr; event bus</span>
  </p>

  <div
    id="cc-odometer"
    class="odometer"
    role="status"
    aria-live="polite"
    aria-label="0"
    data-value="0"
  >
  </div>

  <p class="odometer-card__status" data-odometer-status>Waiting for the first update&hellip;</p>

  <form class="odometer-card__form" data-odometer-form>
    <input
      class="odometer-card__input"
      type="number"
      name="value"
      step="any"
      placeholder="Enter a value"
      aria-label="Value to broadcast on the odometer topic"
      required
    />
    <button class="odometer-card__submit" type="submit">Send event</button>
  </form>
</div>

<style>
  .odometer-card {
    display: inline-flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 28px;
    padding: 28px 32px;
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: 14px;
  }

  .odometer-card__label {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    font-size: 15px;
    color: var(--cc-text-secondary);
  }

  .odometer-card__hint {
    font-size: 13px;
    color: var(--cc-text-muted);
  }

  .odometer-card__hint code {
    font-family: ui-monospace, "SF Mono", monospace;
    color: var(--cc-accent);
  }

  .odometer-card__status {
    margin: 0;
    font-size: 13px;
    color: var(--cc-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .odometer-card__form {
    display: flex;
    gap: 8px;
  }

  .odometer-card__input {
    flex: 1;
    min-width: 0;
    padding: 8px 10px;
    font-size: 15px;
    color: var(--cc-text);
    background: var(--cc-surface-2);
    border: 1px solid var(--cc-border-strong);
    border-radius: 8px;
  }

  .odometer-card__input:focus-visible {
    outline: none;
    border-color: var(--cc-accent);
  }

  .odometer-card__submit {
    padding: 8px 14px;
    font-size: 15px;
    font-weight: 600;
    color: var(--cc-bg);
    background: var(--cc-accent);
    border: 0;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .odometer-card__submit:hover {
    opacity: 0.85;
  }

  /* The digit columns/strips are built in JS, so they never carry Astro's
     scope hash -- reach them with :global() under the template-scoped root. */
  .odometer {
    display: inline-flex;
    align-items: stretch;
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--cc-text);
  }

  /* Osmo "Number Odometer" model: each digit is a mask that clips to one line
     over a roller -- a single text node of 0-9 repeated (stacked by line
     height). Rolling = translateY the roller. Built in JS, so reached with
     :global() under the template-scoped root. */
  .odometer :global(.odometer__col) {
    display: inline-block;
    overflow: clip;
    height: 1em;
    /* breathing room so glyph antialiasing isn't clipped at the 1em edges */
    padding: 0.06em;
    margin: -0.06em;
  }

  .odometer :global(.odometer__strip) {
    display: block;
    white-space: pre;
    text-align: center;
    line-height: 1;
  }

  .odometer :global(.odometer__static) {
    display: inline-block;
  }
</style>

<script>
  // Module script: evaluated once and preserved across Astro view transitions
  // (like EventBusInit), so the astro:page-load / astro:before-swap listeners
  // below are registered exactly once. enter()'s own guard keeps the immediate
  // call and the first page-load from double-subscribing.
  // Number odometer, adapted to vanilla + the Web Animations API (no GSAP) and
  // driven by the event bus. Each update rolls from the CURRENTLY displayed
  // value like a real counter: unchanged digits stay put, and changed digits
  // roll in the direction of the change -- up when the value increases, down
  // when it decreases -- wrapping only on a genuine carry (e.g. 9->0 on an
  // increase). Each roller is a 0-9 ribbon repeated 3x with the start digit
  // seeded in the middle cycle, leaving room to roll either way.
  function createOdometer(root: HTMLElement) {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const EASE = "cubic-bezier(0.16, 1, 0.3, 1)"; // ~power3.out
    let current = ""; // last displayed string; "" until the first render

    const isDigit = (ch: string) => ch >= "0" && ch <= "9";
    const digitCount = (n: number) => String(Math.abs(Math.trunc(n || 0))).length;

    function set(value: number) {
      const num = Number(value);
      if (!Number.isFinite(num)) return;
      const target = String(num);
      if (target === current) return;
      const prev = Number(current); // NaN on the first render
      const animate = current !== "" && Number.isFinite(prev) && !reduce;
      const up = !(num < prev); // increases (and the first render) roll up

      // Seed each column from the digits currently shown, padded to the new
      // digit count so freshly grown columns still have a start to roll from.
      const startValue = parseInt([...current].filter(isDigit).join(""), 10) || 0;
      const digitSlots = [...target].filter(isDigit).length;
      const paddedStart = String(Math.abs(startValue))
        .padStart(digitSlots, "0")
        .slice(-digitSlots);

      // The bigger the jump in digit count (small -> very large, or the
      // reverse), the more extra full rotations every column spins before
      // landing -- a dynamic "spin-up". Same-width changes (e.g. 10 -> 11) get
      // no extra spins and stay crisp. The ribbon is padded on both sides so a
      // spin fits whichever way it rolls; the start digit sits in the middle.
      const spins = animate ? Math.min(3, Math.abs(digitSlots - digitCount(prev))) : 0;
      const pad = spins + 1;
      const cellCount = (2 * pad + 1) * 10;
      const mid = pad * 10;

      root.textContent = "";
      const rollers: { roller: HTMLElement; seed: number; dest: number; dist: number }[] = [];
      let di = 0;
      for (const ch of target) {
        if (!isDigit(ch)) {
          const stat = document.createElement("span");
          stat.className = "odometer__static";
          stat.textContent = ch;
          root.appendChild(stat);
          continue;
        }
        const mask = document.createElement("span");
        mask.className = "odometer__col";
        const roller = document.createElement("span");
        roller.className = "odometer__strip";
        const cells: number[] = [];
        for (let i = 0; i < cellCount; i++) cells.push(i % 10);
        roller.textContent = cells.join("\n");
        mask.appendChild(roller);
        root.appendChild(mask);

        const startDigit = Number(paddedStart[di]);
        const endDigit = Number(ch);
        // Steps to the target in the chosen direction, plus the spin-up spins.
        // A total distance of 0 means the digit is unchanged -> it stays put.
        const steps = up
          ? (endDigit - startDigit + 10) % 10
          : (startDigit - endDigit + 10) % 10;
        const dist = steps + spins * 10;
        const seed = mid + startDigit; // ribbon index currently shown
        const dest = up ? seed + dist : seed - dist; // lands on endDigit
        rollers.push({ roller, seed, dest, dist });
        di++;
      }

      // Scale roll time and the digit cascade with the biggest distance rolled,
      // so a small tick is snappy but a big jump feels weighty.
      const maxDist = rollers.reduce((m, r) => Math.max(m, r.dist), 0);
      const duration = Math.min(1400, 380 + 26 * maxDist);
      const stagger = Math.min(80, 30 + rollers.length * 7);

      rollers.forEach(({ roller, seed, dest, dist }, idx) => {
        roller.style.transform = `translateY(-${dest}em)`;
        if (!animate || dist === 0) return;
        const delay = (rollers.length - 1 - idx) * stagger;
        roller.animate(
          [{ transform: `translateY(-${seed}em)` }, { transform: `translateY(-${dest}em)` }],
          { duration, easing: EASE, delay, fill: "backwards" },
        );
      });

      current = target;
      root.dataset.value = target;
      root.setAttribute("aria-label", target);
    }

    return { set };
  }

  (function () {
    type CcEvents = {
      subscribe: (topic: string, fn: (data: unknown, topic: string) => void) => () => void;
      publish: (topic: string, data: unknown) => void;
      status: () => { ws: string; webtransport: string };
    };

    let unsubscribe: (() => void) | null = null;

    function transportLabel(bus: CcEvents) {
      const s = bus.status ? bus.status() : { ws: "", webtransport: "" };
      if (s.webtransport === "connected") return "via WebTransport";
      if (s.ws === "connected") return "via WebSocket";
      return "";
    }

    // Wire the "submit a value" form: publish an odometer event onto the bus.
    // The server rebroadcasts it to every subscriber (including us), and the
    // subscription below is what actually rolls the digits -- the form never
    // touches the odometer directly. Guarded per-element since the card's DOM
    // is replaced on navigation.
    function wireForm(bus: CcEvents) {
      const form = document.querySelector<HTMLFormElement>("[data-odometer-form]");
      if (!form || form.dataset.wired === "true") return;
      form.dataset.wired = "true";
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const input = form.querySelector<HTMLInputElement>("input[name=value]");
        if (!input || input.value === "") return;
        const n = Number(input.value);
        if (Number.isNaN(n)) return;
        bus.publish("odometer", { value: n });
      });
    }

    function enter() {
      const root = document.getElementById("cc-odometer");
      if (!root) return;
      const bus = (window as unknown as { __ccEvents?: CcEvents }).__ccEvents;
      // EventBusInit's module script may not have run yet on the very first
      // paint; retry shortly.
      if (!bus) {
        setTimeout(enter, 100);
        return;
      }

      wireForm(bus);

      // The `unsubscribe` guard keeps the immediate call and the first
      // page-load from double-subscribing the odometer.
      if (unsubscribe) return;

      const od = createOdometer(root);
      od.set(Number(root.dataset.value) || 0);
      const status = document.querySelector<HTMLElement>("[data-odometer-status]");

      unsubscribe = bus.subscribe("odometer", (data) => {
        const raw =
          data && typeof data === "object" ? (data as { value?: unknown }).value : data;
        const n = Number(raw);
        if (Number.isNaN(n)) return;
        od.set(n);
        if (status) {
          const how = transportLabel(bus);
          status.textContent = how ? `Updated to ${n} · ${how}` : `Updated to ${n}`;
        }
      });
    }

    function leave() {
      if (unsubscribe) {
        unsubscribe();
        unsubscribe = null;
      }
    }

    enter();
    document.addEventListener("astro:page-load", enter);
    document.addEventListener("astro:before-swap", leave);
  })();
</script>
