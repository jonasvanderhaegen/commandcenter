---
// Custom frameless window title bar (Tauri decorations:false). Native traffic
// lights are gone; this provides the drag region + minimize/maximize/close.
// Only shown inside Tauri (window.__TAURI__); in a plain browser it stays hidden
// and the layout offset is not applied.
---

<div class="titlebar" data-tauri-drag-region>
  <div class="titlebar__controls">
    <button type="button" class="titlebar__btn" data-tb="minimize" aria-label="Minimize">
      <svg viewBox="0 0 12 12" aria-hidden="true"><line x1="2.5" y1="6" x2="9.5" y2="6"></line></svg>
    </button>
    <button type="button" class="titlebar__btn" data-tb="maximize" aria-label="Maximize">
      <svg class="tb-ic tb-ic--max" viewBox="0 0 12 12" aria-hidden="true"><rect x="2.75" y="2.75" width="6.5" height="6.5"></rect></svg>
      <svg class="tb-ic tb-ic--restore" viewBox="0 0 12 12" aria-hidden="true" style="display: none"><rect x="2.5" y="4" width="5.5" height="5.5"></rect><rect x="4" y="2.5" width="5.5" height="5.5"></rect></svg>
    </button>
    <button type="button" class="titlebar__btn titlebar__btn--close" data-tb="close" aria-label="Close">
      <svg viewBox="0 0 12 12" aria-hidden="true"><line x1="3" y1="3" x2="9" y2="9"></line><line x1="9" y1="3" x2="3" y2="9"></line></svg>
    </button>
  </div>
</div>

<style is:global>
  :root {
    --titlebar-h: 20px;
  }

  /* Hidden until we know we're inside Tauri (set by the script below). */
  .titlebar {
    display: none;
  }

  html.is-tauri .titlebar {
    position: fixed;
    inset: 0 0 auto 0;
    height: var(--titlebar-h);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    -webkit-user-select: none;
    user-select: none;
  }

  /* When the nav menu opens, darken the title bar with the same scrim as the
     page (.nav__bg = rgba(0,0,0,0.3)) and fade it in/out with the menu. */
  html.is-tauri .titlebar::after {
    content: "";
    position: absolute;
    inset: 0;
    background-color: #0000004d;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--animation-default),
      visibility var(--animation-default);
  }
  body:has(.nav[data-nav-status="active"]) .titlebar::after {
    opacity: 1;
    visibility: visible;
  }

  /* Push the app (flow content + the fixed Osmo nav) below the bar. */
  html.is-tauri body {
    padding-top: var(--titlebar-h);
  }
  html.is-tauri .nav,
  html.is-tauri .under-nav-bar {
    top: var(--titlebar-h);
  }

  .titlebar__controls {
    display: flex;
    height: 100%;
  }

  .titlebar__btn {
    width: 46px;
    height: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    margin: 0;
    padding: 0;
    background: transparent;
    color: var(--color-purple);
    opacity: 0.8;
    cursor: pointer;
    transition: opacity 0.12s ease;
  }

  .titlebar__btn svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    stroke-width: 1.2;
    fill: none;
  }

  .titlebar__btn:hover {
    background: transparent;
    opacity: 1;
  }

  /* The medium purple loses contrast over dark sections showing through the
     transparent bar. The nav theme tracker already flags those: it sets
     data-nav-theme="dark" on the nav at load (dark pages) and during Lenis
     scroll (dark sections). Reuse that signal -- same body:has() hook as the
     menu scrim above -- to brighten the controls so they stay legible. */
  body:has(.nav[data-nav-theme="dark"]) .titlebar__btn {
    color: color-mix(in srgb, var(--color-purple), white 35%);
    opacity: 0.92;
  }
  body:has(.nav[data-nav-theme="dark"]) .titlebar__btn:hover {
    opacity: 1;
  }
</style>

<script is:inline>
  (function () {
    var tauri = window.__TAURI__;
    if (!tauri || !tauri.window) return; // plain browser: leave the bar hidden

    document.documentElement.classList.add("is-tauri");

    function appWindow() {
      var w = tauri.window;
      if (typeof w.getCurrentWindow === "function") return w.getCurrentWindow();
      if (typeof w.getCurrent === "function") return w.getCurrent();
      return null;
    }

    function syncMaximized() {
      var win = appWindow();
      if (!win || typeof win.isMaximized !== "function") return;
      Promise.resolve(win.isMaximized())
        .then(function (max) {
          document.documentElement.classList.toggle("is-maximized", !!max);
          var b = document.querySelector('.titlebar__btn[data-tb="maximize"]');
          if (b) b.setAttribute("aria-label", max ? "Restore" : "Maximize");
          // Drive the icon swap from JS so it never depends on bundled CSS:
          // exactly one of the two squares is visible at a time.
          var mx = document.querySelector(".tb-ic--max");
          var rs = document.querySelector(".tb-ic--restore");
          if (mx) mx.style.display = max ? "none" : "";
          if (rs) rs.style.display = max ? "" : "none";
        })
        .catch(function () {});
    }

    var actions = {
      minimize: function (win) { return win.minimize(); },
      maximize: function (win) { return win.toggleMaximize(); },
      close: function (win) { return win.close(); },
    };

    document.querySelectorAll(".titlebar__btn").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var win = appWindow();
        var fn = actions[btn.dataset.tb];
        if (!win || !fn) return;
        var p = fn(win);
        if (p && p.then) p.then(syncMaximized);
        else setTimeout(syncMaximized, 50);
      });
    });

    // Reflect the current maximize state on load and on every resize (covers
    // double-click-to-maximize and OS-level maximize/restore).
    syncMaximized();
    var winForEvents = appWindow();
    if (winForEvents && typeof winForEvents.onResized === "function") {
      winForEvents.onResized(function () { syncMaximized(); });
    }
  })();
</script>
