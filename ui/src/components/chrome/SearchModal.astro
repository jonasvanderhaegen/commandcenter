---
// Global ⌘K / Ctrl+K search modal: dimmed backdrop, centered command-palette
// input. Any element with [data-search-trigger] opens it.
---

<div class="search-modal" id="searchModal" data-open="false">
  <div class="search-modal__backdrop" id="searchModalBackdrop"></div>
  <div class="search-modal__panel" role="dialog" aria-modal="true" aria-label="Search">
    <div class="search-modal__input-row">
      <span class="search-modal__icon" aria-hidden="true">&#9906;</span>
      <input
        type="text"
        class="search-modal__input"
        id="searchModalInput"
        placeholder="Search for pages or resources"
        autocomplete="off"
      />
    </div>
    <div class="search-modal__hint">
      <kbd>&#8593;&#8595;</kbd>
      <span>to navigate</span>
      <kbd>Enter</kbd>
      <span>to select</span>
    </div>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1200;
    display: flex;
    justify-content: center;
    padding-top: 18vh;
    pointer-events: none;
  }

  .search-modal__backdrop {
    position: fixed;
    inset: 0;
    background: var(--cc-backdrop);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.18s ease;
  }

  .search-modal__panel {
    position: relative;
    width: min(560px, calc(100vw - 32px));
    height: fit-content;
    background: var(--cc-surface-2);
    border: 1px solid var(--cc-border-strong);
    border-radius: 12px;
    box-shadow: 0 24px 60px var(--cc-shadow);
    padding: 4px;
    opacity: 0;
    transform: scale(0.97) translateY(-6px);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .search-modal[data-open="true"] {
    pointer-events: auto;
  }

  .search-modal[data-open="true"] .search-modal__backdrop {
    opacity: 1;
  }

  .search-modal[data-open="true"] .search-modal__panel {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .search-modal__input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }

  .search-modal__icon {
    opacity: 0.5;
  }

  .search-modal__input {
    flex: 1;
    border: 0;
    background: transparent;
    color: var(--cc-text);
    font-size: 15px;
    outline: none;
  }

  .search-modal__input::placeholder {
    color: var(--cc-text-muted);
  }

  .search-modal__hint {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-top: 1px solid var(--cc-border);
    font-size: 12px;
    color: var(--cc-text-muted);
  }

  .search-modal__hint kbd {
    font-family: inherit;
    background: var(--cc-hover-bg);
    border-radius: 4px;
    padding: 2px 6px;
    color: var(--cc-text-secondary);
  }
</style>

<script is:inline>
  (function () {
    var modal = document.getElementById("searchModal");
    var backdrop = document.getElementById("searchModalBackdrop");
    var input = document.getElementById("searchModalInput");
    if (!modal || !input) return;

    function open() {
      modal.dataset.open = "true";
      setTimeout(function () {
        input.focus();
      }, 0);
    }

    function close() {
      modal.dataset.open = "false";
      input.value = "";
      input.blur();
    }

    document.querySelectorAll("[data-search-trigger]").forEach(function (el) {
      el.addEventListener("click", open);
    });

    if (backdrop) backdrop.addEventListener("click", close);

    document.addEventListener("keydown", function (e) {
      var isCmdK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k";
      if (isCmdK) {
        e.preventDefault();
        if (modal.dataset.open === "true") close(); else open();
        return;
      }
      if (e.key === "Escape" && modal.dataset.open === "true") {
        close();
      }
    });
  })();
</script>
