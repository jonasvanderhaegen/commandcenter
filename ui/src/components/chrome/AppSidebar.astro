---
// Left app sidebar: a fixed rail on desktop, a full-screen overlay panel on
// narrow viewports (toggled by the hamburger button). The account row at the
// bottom opens a menu upward (transform-origin: bottom) since there's no room
// below it, and shows on hover/focus rather than click. The brand row at the
// top is the Tauri window drag region (decorations:false has no native
// titlebar to drag from otherwise).
---

<button
  type="button"
  class="sidebar-toggle"
  id="sidebarToggle"
  aria-label="Toggle menu"
  aria-expanded="false"
  aria-controls="appSidebar"
>
  <span class="sidebar-toggle__icon" aria-hidden="true"></span>
</button>

<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<aside class="sidebar" id="appSidebar">
  <div class="sidebar__brand" data-tauri-drag-region>
    <span class="sidebar__brand-mark" aria-hidden="true">&gt;_</span>
    <span class="sidebar__brand-name">CommandCenter</span>
  </div>

  <nav class="sidebar__nav" aria-label="Primary">
    <div class="sidebar__nav-row" data-nav-group="true" data-expanded="true">
      <a href="/" class="sidebar__item" data-sidebar-link>
        <span class="sidebar__item-icon" aria-hidden="true">&#9670;</span>
        <span>Projects</span>
      </a>
      <button
        type="button"
        class="sidebar__nav-chevron"
        data-sidebar-subnav-toggle
        aria-label="Toggle Projects submenu"
      >
        <svg viewBox="0 0 10 10" aria-hidden="true"><path d="M2.5 3.5L5 6.5l2.5-3"></path></svg>
      </button>
    </div>
    <div class="sidebar__group-collapse">
      <div class="sidebar__group">
        <a class="sidebar__subitem" href="#">Processes</a>
        <a class="sidebar__subitem" href="#">Agents</a>
        <a class="sidebar__subitem" href="#">Terminals</a>
      </div>
    </div>
  </nav>

  <div class="sidebar__secondary">
    <a class="sidebar__item" href="#">
      <span class="sidebar__item-icon" aria-hidden="true">&#9636;</span>
      <span>Templates</span>
    </a>
    <a class="sidebar__item" href="/docs" data-sidebar-link>
      <span class="sidebar__item-icon" aria-hidden="true">&#9636;</span>
      <span>Docs</span>
    </a>
  </div>

  <div class="sidebar__account">
    <button
      type="button"
      class="sidebar__account-trigger"
      id="accountToggle"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="accountMenu"
    >
      <span class="sidebar__account-avatar" aria-hidden="true">C</span>
      <span class="sidebar__account-name">CommandCenter</span>
      <span class="sidebar__account-kebab" aria-hidden="true">&#8942;</span>
    </button>

    <div class="sidebar__account-menu" id="accountMenu" role="menu">
      <button type="button" class="sidebar__menu-item" id="gridMenuToggle" role="menuitemcheckbox" aria-pressed="false">
        <span>Column grid</span>
        <span class="sidebar__menu-shortcut">G</span>
      </button>
      <hr class="sidebar__menu-divider" />
      <div class="sidebar__theme-row">
        <div class="sidebar__theme-switch" role="radiogroup" aria-label="Theme" style={`--sidebar-theme-count: 3`}>
          <div class="sidebar__theme-indicator" aria-hidden="true"></div>
          <button type="button" class="sidebar__theme-btn" data-theme-option="light" role="radio" aria-checked="false" aria-label="Light">&#9728;</button>
          <button type="button" class="sidebar__theme-btn" data-theme-option="dark" role="radio" aria-checked="false" aria-label="Dark">&#9790;</button>
          <button type="button" class="sidebar__theme-btn" data-theme-option="system" role="radio" aria-checked="false" aria-label="System">&#9682;</button>
        </div>
      </div>
      <hr class="sidebar__menu-divider" />
      <a class="sidebar__menu-item" href="/secrets" data-sidebar-link role="menuitem">Secrets</a>
      <a class="sidebar__menu-item" href="#" role="menuitem">Settings</a>
      <a class="sidebar__menu-item" href="#" role="menuitem">Report a bug</a>
    </div>
  </div>
</aside>

<button
  type="button"
  class="sidebar-collapse"
  id="sidebarCollapse"
  aria-label="Collapse sidebar"
  aria-expanded="true"
>
  <svg viewBox="0 0 10 10" aria-hidden="true"><path d="M6.5 1.5L2.5 5l4 3.5"></path></svg>
</button>

<style>
  #appSidebar,
  #appSidebar *,
  #accountMenu,
  #accountMenu * {
    box-sizing: border-box;
  }

  .sidebar {
    position: fixed;
    top: calc(var(--titlebar-h, 0px) + 8px);
    left: 8px;
    bottom: 8px;
    width: 224px;
    display: flex;
    flex-direction: column;
    background: var(--cc-surface);
    border: 1px solid var(--cc-border);
    border-radius: 12px;
    padding: 16px 10px 8px;
    z-index: 900;
    /* Same snappy custom ease this site's own vendored GSAP setup uses
       elsewhere (CustomEase "osmo": 0.625, 0.05, 0, 1) for menu/nav moves. */
    transition:
      width 0.32s cubic-bezier(0.625, 0.05, 0, 1),
      padding 0.32s cubic-bezier(0.625, 0.05, 0, 1),
      transform 0.28s ease,
      opacity 0.28s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .sidebar__brand {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 6px 14px;
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--cc-text);
  }

  .sidebar__brand-mark {
    color: var(--cc-accent);
    font-family: ui-monospace, "SF Mono", monospace;
  }

  .sidebar__brand-name {
    flex: 1;
  }

  .sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar__item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 9px;
    border-radius: 7px;
    color: var(--cc-text-secondary);
    text-decoration: none;
    font-size: 17px;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .sidebar__item:hover {
    background: var(--cc-hover-bg);
    color: var(--cc-text);
  }

  .sidebar__item--active {
    background: var(--cc-active-bg);
    color: var(--cc-text);
  }

  .sidebar__item-icon {
    font-size: 14px;
    opacity: 0.7;
    width: 16px;
    text-align: center;
  }

  .sidebar__nav-row {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .sidebar__nav-row .sidebar__item {
    flex: 1;
  }

  .sidebar__nav-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--cc-text-muted);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .sidebar__nav-chevron:hover {
    background: var(--cc-hover-bg);
    color: var(--cc-text);
  }

  .sidebar__nav-chevron svg {
    width: 9px;
    height: 9px;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    transform: rotate(-90deg);
    transition: transform 0.2s cubic-bezier(0.625, 0.05, 0, 1);
  }

  [data-nav-group][data-expanded="true"] .sidebar__nav-chevron svg {
    transform: rotate(0deg);
  }

  /* Same height-animated collapse as DocsNav's accordion: grid-template-rows,
     no JS height measurement needed. */
  .sidebar__group-collapse {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s cubic-bezier(0.625, 0.05, 0, 1);
  }

  [data-nav-group][data-expanded="true"] + .sidebar__group-collapse {
    grid-template-rows: 1fr;
  }

  .sidebar__group-collapse > .sidebar__group {
    overflow: hidden;
  }

  .sidebar__group {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 2px 0 12px 26px;
    padding-left: 14px;
  }

  .sidebar__subitem {
    position: relative;
    padding: 5px 8px;
    border-radius: 6px;
    font-size: 16px;
    color: var(--cc-text-muted);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .sidebar__subitem::before {
    content: "";
    position: absolute;
    left: -14px;
    top: -1px;
    width: 14px;
    height: 15px;
    border-left: 1px solid var(--cc-border-strong);
    border-bottom: 1px solid var(--cc-border-strong);
    border-bottom-left-radius: 8px;
  }

  .sidebar__subitem::after {
    content: "";
    position: absolute;
    left: -14px;
    top: 14px;
    bottom: -1px;
    width: 1px;
    background: var(--cc-border-strong);
  }

  .sidebar__subitem:last-child::after {
    display: none;
  }

  .sidebar__subitem:hover {
    background: var(--cc-hover-bg);
    color: var(--cc-text-secondary);
  }

  .sidebar__secondary {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid var(--cc-border);
  }

  .sidebar__account {
    position: relative;
    margin-top: auto;
    padding-top: 12px;
  }

  .sidebar__account-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    /* Same 8px used for the sidebar's own inset from the window edge --
       keeps the padding/radius relationship consistent at both nesting
       levels (window -> sidebar -> this row). */
    padding: 8px;
    border: 1px solid var(--cc-border);
    border-radius: 12px;
    background: transparent;
    color: var(--cc-text);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .sidebar__account-trigger:hover {
    background: var(--cc-hover-bg);
  }

  .sidebar__account-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cc-hover-bg);
    color: var(--cc-text);
    font-size: 14px;
    font-weight: 600;
  }

  .sidebar__account-name {
    font-size: 16px;
    flex: 1;
    text-align: left;
    color: var(--cc-text-secondary);
  }

  .sidebar__account-kebab {
    opacity: 0.5;
  }

  /* Opens UPWARD: anchored to the bottom of the trigger, animates from below. */
  .sidebar__account-menu {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(100% + 6px);
    transform-origin: bottom;
    background: var(--cc-surface-2);
    border: 1px solid var(--cc-border-strong);
    border-radius: 10px;
    padding: 6px;
    box-shadow: 0 12px 32px var(--cc-shadow);
    display: flex;
    flex-direction: column;
    gap: 1px;

    opacity: 0;
    visibility: hidden;
    transform: scale(0.96) translateY(6px);
    transition:
      opacity 0.16s ease,
      transform 0.16s ease,
      visibility 0.16s;
  }

  /* Fixed width in the collapsed rail so the menu's content (labels, the
     3-way appearance switch) doesn't get squeezed into 52px. */
  html.sidebar-collapsed .sidebar__account-menu {
    left: 0;
    right: auto;
    width: 224px;
  }

  .sidebar__account:hover .sidebar__account-menu,
  .sidebar__account:focus-within .sidebar__account-menu {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
  }

  .sidebar__theme-row {
    display: flex;
    padding: 2px;
  }

  .sidebar__theme-switch {
    position: relative;
    display: flex;
    flex: 1;
    gap: 2px;
    background: var(--cc-hover-bg);
    border-radius: 7px;
    padding: 2px;
  }

  /* Sliding pill behind the active option; position driven by --sidebar-theme-index (set in JS). */
  .sidebar__theme-indicator {
    position: absolute;
    top: 2px;
    bottom: 2px;
    left: 2px;
    width: calc((100% - 4px) / var(--sidebar-theme-count, 3));
    border-radius: 5px;
    background: var(--cc-active-bg);
    transform: translateX(calc(100% * var(--sidebar-theme-index, 0)));
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sidebar__theme-btn {
    position: relative;
    z-index: 1;
    flex: 1;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 5px;
    background: transparent;
    color: var(--cc-text-muted);
    font-size: 15px;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .sidebar__theme-btn:hover {
    color: var(--cc-text);
  }

  .sidebar__theme-btn[aria-checked="true"] {
    color: var(--cc-text);
  }

  .sidebar__menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    padding: 7px 8px;
    border: 0;
    background: transparent;
    border-radius: 6px;
    color: var(--cc-text-secondary);
    font-size: 16px;
    text-decoration: none;
    text-align: left;
    cursor: pointer;
  }

  .sidebar__menu-item:hover {
    background: var(--cc-hover-bg);
  }

  .sidebar__menu-item--danger {
    color: var(--cc-danger);
  }

  .sidebar__menu-divider {
    border: 0;
    border-top: 1px solid var(--cc-border);
    margin: 4px 2px;
  }

  .sidebar__menu-shortcut {
    font-size: 13px;
    color: var(--cc-text-muted);
  }

  /* Mobile hamburger + overlay behavior */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: calc(var(--titlebar-h, 0px) + 10px);
    right: 14px;
    z-index: 1100;
    width: 34px;
    height: 34px;
    border: 1px solid var(--cc-border-strong);
    border-radius: 8px;
    background: var(--cc-surface-2);
    cursor: pointer;
  }

  .sidebar-toggle__icon,
  .sidebar-toggle__icon::before,
  .sidebar-toggle__icon::after {
    content: "";
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--cc-text);
    position: relative;
    margin: 0 auto;
  }

  .sidebar-toggle__icon::before {
    position: absolute;
    top: -5px;
  }

  .sidebar-toggle__icon::after {
    position: absolute;
    top: 5px;
  }

  .sidebar-backdrop {
    display: none;
  }

  /* Collapse toggle: sits in the existing gutter between the sidebar's right
     edge (8px inset + 200px width = 208px) and the content's start (224px),
     so nothing overlaps it. Hidden until the sidebar (or the button itself)
     is hovered/focused, or while collapsed (otherwise there'd be no way to
     expand again). Desktop only -- the mobile hamburger overlay handles
     narrow viewports on its own. */
  .sidebar-collapse {
    position: fixed;
    /* Aligned with the brand row's vertical center: sidebar top inset (8px)
       + sidebar padding-top (16px) + ~half the brand row's line height. */
    top: 33px;
    left: 232px;
    transform: translate(-50%, -50%);
    z-index: 910;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 50%;
    background: var(--cc-surface-2);
    color: var(--cc-text-muted);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.15s ease,
      left 0.32s cubic-bezier(0.625, 0.05, 0, 1),
      background 0.15s ease,
      color 0.15s ease;
  }

  /* Border on the right half only: draw a full circular border on the
     pseudo-element, then clip away the left 50% so just the right arc
     shows. */
  .sidebar-collapse::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid var(--cc-border-strong);
    clip-path: inset(0 0 0 50%);
    pointer-events: none;
  }

  .sidebar-collapse svg {
    width: 9px;
    height: 9px;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    transition: transform 0.32s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .sidebar:hover ~ .sidebar-collapse,
  .sidebar-collapse:hover,
  .sidebar-collapse:focus-visible {
    opacity: 1;
  }

  .sidebar-collapse:hover {
    color: var(--cc-text);
  }

  /* Collapsed: shrink to an icon-only rail instead of vanishing entirely --
     labels/subitems fade out, icons stay centered. */
  html.sidebar-collapsed .sidebar {
    width: 52px;
    padding-left: 6px;
    padding-right: 6px;
  }

  html.sidebar-collapsed .sidebar__brand {
    justify-content: center;
    padding-left: 0;
    padding-right: 0;
  }

  html.sidebar-collapsed .sidebar__brand-name,
  html.sidebar-collapsed .sidebar__item span:not(.sidebar__item-icon),
  html.sidebar-collapsed .sidebar__group,
  html.sidebar-collapsed .sidebar__account-name,
  html.sidebar-collapsed .sidebar__account-kebab {
    display: none;
  }

  html.sidebar-collapsed .sidebar__item,
  html.sidebar-collapsed .sidebar__account-trigger {
    justify-content: center;
  }

  html.sidebar-collapsed .sidebar-collapse {
    left: 60px;
    opacity: 1;
  }

  html.sidebar-collapsed .sidebar-collapse svg {
    transform: scaleX(-1);
  }

  @media (max-width: 900px) {
    .sidebar-collapse {
      display: none;
    }

    .sidebar-toggle {
      display: block;
    }

    .sidebar {
      top: 0;
      left: 0;
      bottom: 0;
      width: 100%;
      max-width: 420px;
      border-radius: 0;
      border-left: 0;
      padding-top: calc(var(--titlebar-h, 0px) + 16px);
      transform: translateX(-100%);
      opacity: 0;
    }

    html.sidebar-open .sidebar {
      transform: translateX(0);
      opacity: 1;
    }

    .sidebar-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: var(--cc-backdrop);
      z-index: 890;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s;
    }

    html.sidebar-open .sidebar-backdrop {
      opacity: 1;
      visibility: visible;
    }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById("sidebarToggle");
    var backdrop = document.getElementById("sidebarBackdrop");
    var html = document.documentElement;

    function setSidebarOpen(open) {
      html.classList.toggle("sidebar-open", open);
      if (toggle) toggle.setAttribute("aria-expanded", String(open));
    }

    if (toggle) {
      toggle.addEventListener("click", function () {
        setSidebarOpen(!html.classList.contains("sidebar-open"));
      });
    }

    document.querySelectorAll("[data-sidebar-subnav-toggle]").forEach(function (btn) {
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        var group = btn.closest("[data-nav-group]");
        if (!group) return;
        group.dataset.expanded = String(group.dataset.expanded !== "true");
      });
    });

    var collapseBtn = document.getElementById("sidebarCollapse");
    function syncCollapseButton() {
      if (!collapseBtn) return;
      var collapsed = window.__ccSidebar && window.__ccSidebar.get();
      collapseBtn.setAttribute("aria-expanded", String(!collapsed));
      collapseBtn.setAttribute("aria-label", collapsed ? "Expand sidebar" : "Collapse sidebar");
    }
    if (collapseBtn) {
      collapseBtn.addEventListener("click", function () {
        if (window.__ccSidebar) window.__ccSidebar.toggle();
        syncCollapseButton();
      });
    }
    document.addEventListener("cc-sidebar-change", syncCollapseButton);
    syncCollapseButton();

    function syncActiveLink() {
      var path = window.location.pathname;
      document.querySelectorAll("[data-sidebar-link]").forEach(function (link) {
        var href = link.getAttribute("href");
        var active = href === "/" ? path === "/" : path === href || path.indexOf(href + "/") === 0;
        link.classList.toggle("sidebar__item--active", active);
      });
    }
    syncActiveLink();
    document.addEventListener("astro:after-swap", syncActiveLink);
    if (backdrop) {
      backdrop.addEventListener("click", function () {
        setSidebarOpen(false);
      });
    }

    var accountToggle = document.getElementById("accountToggle");
    var accountMenu = document.getElementById("accountMenu");
    if (accountToggle && accountMenu) {
      // Menu opens on hover/focus (CSS); this just keeps aria-expanded in sync.
      var wrap = accountToggle.closest(".sidebar__account");
      if (wrap) {
        wrap.addEventListener("mouseenter", function () {
          accountToggle.setAttribute("aria-expanded", "true");
        });
        wrap.addEventListener("mouseleave", function () {
          accountToggle.setAttribute("aria-expanded", "false");
        });
      }
    }

    // Appearance switch: reflects the mode ThemeInit already applied, and
    // calls window.__ccTheme.set() (defined in ThemeInit.astro) on click.
    var themeButtons = Array.prototype.slice.call(
      document.querySelectorAll("[data-theme-option]")
    );
    var themeSwitch = document.querySelector(".sidebar__theme-switch");
    var themeOrder = themeButtons.map(function (btn) {
      return btn.dataset.themeOption;
    });

    function syncThemeButtons() {
      var mode = (window.__ccTheme && window.__ccTheme.get()) || "system";
      var index = Math.max(themeOrder.indexOf(mode), 0);
      themeButtons.forEach(function (btn) {
        btn.setAttribute("aria-checked", String(btn.dataset.themeOption === mode));
      });
      if (themeSwitch) themeSwitch.style.setProperty("--sidebar-theme-index", String(index));
    }

    themeButtons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        if (window.__ccTheme) window.__ccTheme.set(btn.dataset.themeOption);
        syncThemeButtons();
      });
    });

    document.addEventListener("cc-theme-change", syncThemeButtons);
    syncThemeButtons();

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        setSidebarOpen(false);
        if (document.activeElement) document.activeElement.blur();
      }
    });
  })();
</script>
