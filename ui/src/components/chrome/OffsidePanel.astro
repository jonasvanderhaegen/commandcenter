---
// Reusable off-canvas side panel (the "offside panel" pattern): a backdrop +
// panel that slides in from an edge, using the same sweet-ease bezier as the
// rest of the app's chrome (sidebar collapse, docs-nav accordion). Content is
// fully consumer-supplied via slots -- this component only owns the
// open/close mechanics and the slide/fade animation.
//
// Usage:
//   <OffsidePanel id="my-panel" label="Add secret">
//     <Fragment slot="header">...</Fragment>
//     ...body...
//     <Fragment slot="footer">...</Fragment>
//   </OffsidePanel>
//
// Open/close from other scripts via the element itself:
//   document.getElementById("my-panel").offsideOpen();
//   document.getElementById("my-panel").offsideClose();
// A "cc-offside-change" event fires on the element on every open/close, with
// `detail: { open: boolean }`, for consumers that want to react (reset a
// form, refocus something, etc.) instead of polling.
type Props = {
  id: string;
  label: string;
  side?: "left" | "right";
  width?: string;
};

const { id, label, side = "right", width = "380px" } = Astro.props;
---

<div
  class="offside-overlay"
  id={id}
  data-offside-panel
  data-side={side}
  data-open="false"
  style={`--offside-width: ${width}`}
>
  <div class="offside-panel" role="dialog" aria-modal="true" aria-label={label}>
    <header class="offside-panel__header">
      <slot name="header" />
      <button type="button" class="offside-panel__close" data-offside-close aria-label="Close">
        &times;
      </button>
    </header>
    <div class="offside-panel__body">
      <slot />
    </div>
    <footer class="offside-panel__footer">
      <slot name="footer" />
    </footer>
  </div>
</div>

<style is:global>
  .offside-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    justify-content: flex-end;
    background: var(--cc-backdrop);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.32s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .offside-overlay[data-side="left"] {
    justify-content: flex-start;
  }

  .offside-overlay[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .offside-panel {
    width: var(--offside-width, 380px);
    max-width: 100%;
    height: 100%;
    background: var(--cc-surface);
    border-left: 1px solid var(--cc-border-strong);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.625, 0.05, 0, 1);
  }

  .offside-overlay[data-side="left"] .offside-panel {
    border-left: 0;
    border-right: 1px solid var(--cc-border-strong);
    transform: translateX(-100%);
  }

  .offside-overlay[data-open="true"] .offside-panel {
    transform: translateX(0);
  }

  .offside-panel__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 18px 18px 14px;
    border-bottom: 1px solid var(--cc-border);
    flex-shrink: 0;
  }

  .offside-panel__header h2 {
    margin: 0 0 4px;
    font-size: 16px;
    color: var(--cc-text);
  }

  .offside-panel__header p {
    margin: 0;
    font-size: 12px;
    color: var(--cc-text-muted);
    max-width: 26ch;
  }

  .offside-panel__close {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 0;
    background: transparent;
    color: var(--cc-text-muted);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
  }

  .offside-panel__close:hover {
    background: var(--cc-hover-bg);
    color: var(--cc-text);
  }

  .offside-panel__body {
    flex: 1;
    overflow-y: auto;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .offside-panel__footer {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    padding: 12px 18px 18px;
  }

  .offside-panel__footer:empty {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    function wirePanel(panel) {
      if (panel.dataset.wired === "true") return;
      panel.dataset.wired = "true";

      function setOpen(open) {
        panel.dataset.open = String(open);
        panel.dispatchEvent(new CustomEvent("cc-offside-change", { detail: { open: open } }));
      }

      panel.offsideOpen = function () {
        setOpen(true);
      };
      panel.offsideClose = function () {
        setOpen(false);
      };

      panel.querySelectorAll("[data-offside-close]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          panel.offsideClose();
        });
      });

      panel.addEventListener("click", function (e) {
        if (e.target === panel) panel.offsideClose();
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && panel.dataset.open === "true") panel.offsideClose();
      });
    }

    function wireAll() {
      document.querySelectorAll("[data-offside-panel]").forEach(wirePanel);
    }
    wireAll();
    document.addEventListener("astro:page-load", wireAll);
  })();
</script>
