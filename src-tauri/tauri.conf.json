{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CommandCenter",
  "version": "0.0.1",
  "identifier": "dev.commandcenter.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ui && ./node_modules/.bin/astro dev --background --host --port 1420",
    "beforeBuildCommand": "cd ui && ./node_modules/.bin/astro build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CommandCenter",
        "width": 1100,
        "height": 720,
        "minWidth": 400,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
